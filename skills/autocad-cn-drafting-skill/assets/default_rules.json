{
  "rules_version": "0.1.0",
  "units": "mm",
  "model_space_scale": "1:1",
  "text_style": {
    "name": "CN-CAD",
    "preferred_fonts": [
      "simfang.ttf",
      "simsun.ttc",
      "Arial Unicode MS.ttf",
      "Arial.ttf"
    ],
    "fallback_font": "txt.shx",
    "paper_text_height_mm": 3.5
  },
  "dimension_style": {
    "name": "CN-CAD-DIM",
    "paper_text_height_mm": 3.5,
    "arrow_size_mm": 2.5,
    "extension_offset_mm": 1.0,
    "decimal_places": 0
  },
  "sheets": {
    "A4": [210, 297],
    "A3": [297, 420],
    "A2": [420, 594],
    "A1": [594, 841],
    "A0": [841, 1189]
  },
  "layers": {
    "A-WALL-EXST": {"color": 7, "linetype": "CONTINUOUS", "lineweight": 50, "plot": true},
    "A-WALL-NEW": {"color": 1, "linetype": "CONTINUOUS", "lineweight": 50, "plot": true},
    "A-WALL-DEMO": {"color": 1, "linetype": "HIDDEN", "lineweight": 25, "plot": true},
    "A-DOOR": {"color": 3, "linetype": "CONTINUOUS", "lineweight": 25, "plot": true},
    "A-WIND": {"color": 4, "linetype": "CONTINUOUS", "lineweight": 25, "plot": true},
    "A-FLOR-FNSH": {"color": 8, "linetype": "CONTINUOUS", "lineweight": 13, "plot": true},
    "A-CLNG": {"color": 6, "linetype": "CONTINUOUS", "lineweight": 13, "plot": true},
    "A-FURN": {"color": 2, "linetype": "CONTINUOUS", "lineweight": 18, "plot": true},
    "A-FIXT": {"color": 5, "linetype": "CONTINUOUS", "lineweight": 18, "plot": true},
    "A-GRID": {"color": 4, "linetype": "CENTER", "lineweight": 13, "plot": true},
    "A-ANNO-DIMS": {"color": 2, "linetype": "CONTINUOUS", "lineweight": 13, "plot": true},
    "A-ANNO-TEXT": {"color": 7, "linetype": "CONTINUOUS", "lineweight": 13, "plot": true},
    "A-ANNO-SYMB": {"color": 6, "linetype": "CONTINUOUS", "lineweight": 18, "plot": true},
    "A-BORDER": {"color": 7, "linetype": "CONTINUOUS", "lineweight": 35, "plot": true},
    "A-TTLB": {"color": 7, "linetype": "CONTINUOUS", "lineweight": 18, "plot": true},
    "A-REF": {"color": 9, "linetype": "CONTINUOUS", "lineweight": 9, "plot": false},
    "A-NPLT-REVIEW": {"color": 1, "linetype": "DASHED", "lineweight": 18, "plot": false}
  },
  "required_layers": [
    "A-WALL-EXST",
    "A-DOOR",
    "A-WIND",
    "A-ANNO-DIMS",
    "A-ANNO-TEXT",
    "A-BORDER",
    "A-TTLB",
    "A-NPLT-REVIEW"
